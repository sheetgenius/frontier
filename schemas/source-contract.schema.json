{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier.bitter.sh/schemas/source-contract.schema.json",
  "title": "Bitter Frontier Source Contract",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "label",
    "owner",
    "homepage",
    "primary_surfaces",
    "accepted_evidence",
    "rejected_evidence",
    "change_types",
    "high_signal_patterns",
    "operator_questions",
    "default_actionability",
    "discovery",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "bitter.frontier_source_contract.v0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "label": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "primary_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "url", "priority", "watch"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "kind": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "watch": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "accepted_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "change_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "research_lenses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "high_signal_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operator_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_actionability": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "discovery": {
      "type": "object",
      "required": [
        "last_verified",
        "verified_by",
        "confidence",
        "open_questions"
      ],
      "properties": {
        "last_verified": {
          "type": "string",
          "format": "date"
        },
        "verified_by": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
