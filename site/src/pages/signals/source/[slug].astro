---
import Base from "../../../layouts/Base.astro";
import SignalList from "../../../components/SignalList.astro";
import { getProfile, listProfiles, listSignalSourceSlugs, signalsForSource, sourceLabel } from "../../../lib/frontier";
import { metaDescription } from "../../../lib/seo";
import { SITE_URL } from "../../../lib/site";

export function getStaticPaths() {
  return listSignalSourceSlugs().map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug!;
const signals = signalsForSource(slug);
const profiles = listProfiles();
const profileSlugs = new Set(profiles.map((p) => p.slug));
const hasProfile = profileSlugs.has(slug);
const profile = getProfile(slug);
const label = sourceLabel(slug);
const sourceKind = /\bcoding agent\b/i.test(label) ? "Signals" : "Coding Agent Signals";
const title = `${label} ${sourceKind} | Bitter Frontier`;
const description = metaDescription(
  `${label} signal archive: sourced coding-agent changes, release-channel status, operator consequences, and current profile context.`,
  profile?.data.tagline,
  `Every accepted signal for ${label}, in reverse chronological order.`,
);
const keywords = [
  label,
  `${label} signals`,
  `${label} release notes`,
  `${label} coding agent`,
  "AI coding agent signals",
  "Bitter Frontier",
];
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${label} coding agent signals`,
  itemListElement: signals.slice(0, 50).map((signal, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: signal.title,
    url: new URL(`/signals/${signal.id}/`, SITE_URL).toString(),
  })),
};
---

<Base
  title={title}
  description={description}
  keywords={keywords}
  structuredData={signals.length > 0 ? itemList : undefined}
>
  <section class="measure py-10">
    <p class="small-caps text-muted">
      <a href="/signals/">Signals</a>{hasProfile && (
        <>
          {" / "}
          <a href={`/profiles/${slug}/`}>{label} profile</a>
        </>
      )}
    </p>
    <h1 class="issue-title">{label}</h1>
    <p class="signal-intro">
      Sourced signals for {label}: release changes, governance moves, runtime shifts, and operator consequences.
      Each links to the run that produced it.
      {hasProfile && (
        <> The <a href={`/profiles/${slug}/`} class="hover:underline">{label} profile</a> carries the current evergreen state.</>
      )}
    </p>

    {signals.length === 0 ? (
      <p class="mt-9 text-muted">No accepted signals for this source yet.</p>
    ) : (
      <SignalList signals={signals} profileSlugs={profileSlugs} />
    )}

    <p class="rule mt-10 pt-5 font-mono text-sm text-muted">
      <a href="/signals/" class="hover:underline">&lt;- All signals</a>
    </p>
  </section>
</Base>
