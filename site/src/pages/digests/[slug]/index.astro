---
import Base from "../../../layouts/Base.astro";
import NotPromoted from "../../../components/NotPromoted.astro";
import OperatorBrief from "../../../components/OperatorBrief.astro";
import SourceTrail from "../../../components/SourceTrail.astro";
import VersionList from "../../../components/VersionList.astro";
import { GH_BLOB_BASE } from "../../../lib/site";
import { canonicalRunForDigest, formatDate, getDigest, getSignal, listDigests, listProfiles, sourceLabel, versionsForDigest } from "../../../lib/frontier";

export function getStaticPaths() {
  return listDigests().map((digest) => ({ params: { slug: digest.slug } }));
}

const digest = getDigest(Astro.params.slug!);
if (!digest) throw new Error("Digest not found");
const canonicalRun = canonicalRunForDigest(digest);
const versions = versionsForDigest(digest.id);

const allProfiles = listProfiles();
const profileMap = new Map(allProfiles.map((p) => [p.slug, p]));
const coveredProfiles = (digest.data.sources ?? [])
  .map((id: string) => profileMap.get(id))
  .filter(Boolean);

const topSignalIds: string[] = digest.data.top_signal_ids ?? [];
const topSignals = topSignalIds
  .map((id) => getSignal(id))
  .filter(Boolean);
---

<Base title={`${digest.data.title} · Bitter Frontier`}>
  <article class="measure py-10">
    <div class="small-caps text-muted">
      {digest.data.series ?? "Issue"} · Published {formatDate(digest.data.window?.end)}
    </div>
    <OperatorBrief brief={digest.data.operator_brief} />
    <div class="prose-frontier mt-7" set:html={digest.html} />

    {topSignals.length > 0 && (
      <div class="rule mt-10 pt-6">
        <p class="small-caps text-muted">Top signals from this issue</p>
        <ol class="mt-3 top-signals-list">
          {topSignals.map((signal: any) => (
            <li>
              <a href={`/signals/${signal.id}/`} class="no-underline hover:underline">
                <span class="font-mono text-xs text-muted">{sourceLabel(signal.sources[0] ?? "")}</span>
                <span class="block">{signal.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}

    <NotPromoted items={digest.data.not_promoted} />

    {coveredProfiles.length > 0 && (
      <div class="rule mt-9 pt-5">
        <p class="small-caps text-muted">Providers covered</p>
        <div class="mt-3 flex flex-wrap gap-3">
          {coveredProfiles.map((profile: any) => (
            <a
              href={`/profiles/${profile.slug}/`}
              class="font-mono text-sm no-underline hover:underline text-[var(--color-bitter)]"
            >
              {sourceLabel(profile.slug)}
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="rule mt-9 pt-5">
      <p class="font-mono text-sm text-muted">
        This digest was produced by the <a class="hover:underline" href="https://bitter.sh">Bitter</a> autonomous research loop.
      </p>
      <p class="mt-3">
        <a class="view-source" href={`${GH_BLOB_BASE}/${digest.relativePath}`}>
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View source on GitHub
        </a>
      </p>
    </div>
    <SourceTrail sourceIds={digest.data.sources ?? []} />
    <VersionList versions={versions} currentRunId={canonicalRun?.id} />
  </article>
</Base>
