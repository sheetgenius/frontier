---
import Base from "../../layouts/Base.astro";
import { formatDate, listDigests } from "../../lib/frontier";
const digests = listDigests();
---

<Base
  title="Coding Agent Weekly Digests | Bitter Frontier"
  description="Weekly coding agent digests on Codex, Claude Code, Gemini CLI, Pi Coding Agent, Flue, OpenHands, and agent harness governance, releases, and security fixes."
>
  <section class="measure py-10">
    <p class="small-caps text-muted">Digests</p>
    <h1 class="issue-title">Weekly coding agent digests.</h1>
    <p class="signal-summary mt-3">
      Source-backed weekly briefs on coding agents and harnesses: what changed, what shipped, what only merged, and what operators should test next.
    </p>
    <div class="mt-9 space-y-7">
      {
        digests.map((digest) => (
          <a class="block no-underline hover:underline" href={`/digests/${digest.slug}/`}>
            <div class="small-caps text-muted">
              {digest.data.series ? `${digest.data.series} · ` : ""}{formatDate(digest.data.window?.start)} to {formatDate(digest.data.window?.end)}
            </div>
            <h2 class="signal-title">{digest.data.title}</h2>
            <p class="issue-meta">{digest.data.signal_count} signals · {digest.data.finding_count} findings</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
