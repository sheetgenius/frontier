---
import Base from "../../layouts/Base.astro";
import { SITE_URL } from "../../lib/site";
import { formatDate, listDigests } from "../../lib/frontier";
const digests = listDigests();
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Coding agent weekly digests",
  itemListElement: digests.slice(0, 20).map((digest, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: digest.data.title ?? digest.slug,
    url: new URL(`/digests/${digest.slug}/`, SITE_URL).toString(),
  })),
};
---

<Base
  title="AI Coding Agent Weekly Digest Archive | Codex, Claude, Gemini"
  description="Weekly source-backed digest archive for AI coding agents: Codex, Claude Code, Gemini CLI, Pi Coding Agent, Flue, OpenHands, releases, governance, and security fixes."
  keywords={["AI coding agent weekly digest", "coding agent release digest", "Codex", "Claude Code", "Gemini CLI", "Pi Coding Agent", "Flue"]}
  structuredData={itemList}
>
  <section class="measure py-10">
    <p class="small-caps text-muted">Digests</p>
    <h1 class="issue-title">AI coding agent weekly digest archive.</h1>
    <p class="signal-summary mt-3">
      Source-backed weekly briefs on coding agents and harnesses: what changed, what shipped, what only merged,
      and what operators should test next.
    </p>
    <div class="mt-9 space-y-7">
      {
        digests.map((digest) => (
          <a class="block no-underline hover:underline" href={`/digests/${digest.slug}/`}>
            <div class="small-caps text-muted">
              {digest.data.series ? `${digest.data.series} · ` : ""}{formatDate(digest.data.window?.start)} to {formatDate(digest.data.window?.end)}
            </div>
            <h2 class="signal-title">{digest.data.title}</h2>
            <p class="issue-meta">{digest.data.signal_count} signals · {digest.data.finding_count} findings</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
