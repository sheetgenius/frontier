---
import Base from "../../layouts/Base.astro";
import { SITE_URL } from "../../lib/site";
import { listFindings } from "../../lib/frontier";
const findings = listFindings();
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Source-backed coding agent findings",
  itemListElement: findings.slice(0, 30).map((finding, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: finding.title,
    url: new URL(`/findings/${finding.finding}/`, SITE_URL).toString(),
  })),
};
---

<Base
  title="Coding Agent Findings with Receipts | Codex, Claude, Gemini, Pi"
  description="Source-backed coding agent findings with receipts for Codex, Claude Code, Gemini CLI, Pi Coding Agent, Flue, OpenHands, and operator-facing signals."
  keywords={["coding agent findings", "source-backed findings", "Codex", "Claude Code", "Gemini CLI", "Pi Coding Agent"]}
  structuredData={itemList}
>
  <section class="measure py-10">
    <p class="small-caps text-muted">Findings</p>
    <h1 class="issue-title">Source-backed observations.</h1>
    <div class="mt-9 signal-list">
      {
        findings.map((finding) => (
          <a href={`/findings/${finding.finding}/`} class="block no-underline hover:underline">
            <div class="small-caps text-[var(--color-bitter)]">{finding.data.source} · {finding.data.confidence}</div>
            <h2 class="signal-title">{finding.title}</h2>
          </a>
        ))
      }
    </div>
  </section>
</Base>
