---
import Base from "../../../layouts/Base.astro";
import FindingFooter from "../../../components/FindingFooter.astro";
import SourceTrail from "../../../components/SourceTrail.astro";
import { metaDescription } from "../../../lib/seo";
import { getFinding, listFindings, signalsCitingFinding, sourceLabel } from "../../../lib/frontier";

export function getStaticPaths() {
  return listFindings().map((finding) => ({
    params: { runId: finding.runId, finding: finding.finding },
  }));
}

const finding = getFinding(Astro.params.runId!, Astro.params.finding!);
if (!finding) throw new Error("Finding not found");

const citedSignal = signalsCitingFinding(finding)[0];
const findingTitle = finding.title === finding.finding ? (citedSignal?.title ?? finding.title) : finding.title;
const findingDescription = metaDescription(
  finding.data.summary,
  citedSignal?.summary,
  finding.data.operator_consequence,
  citedSignal?.whyActionBearing?.[0],
  finding.body,
  `${findingTitle} source-backed finding for ${sourceLabel(String(finding.data.source ?? "coding agent"))}.`,
);
---

<Base
  title={`${findingTitle} · Bitter Frontier`}
  description={findingDescription}
  canonicalPath={`/findings/${finding.finding}/`}
  robots="noindex, follow"
>
  <article class="measure py-10">
    <p class="small-caps text-muted">Finding · {finding.data.source}</p>
    <div class="prose-frontier mt-7" set:html={finding.html} />
    <FindingFooter finding={finding} />
    <SourceTrail findings={[finding]} title="Source links" />
  </article>
</Base>
