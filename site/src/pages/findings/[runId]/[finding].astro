---
import Base from "../../../layouts/Base.astro";
import FindingFooter from "../../../components/FindingFooter.astro";
import SourceTrail from "../../../components/SourceTrail.astro";
import { getFinding, listFindings } from "../../../lib/frontier";

export function getStaticPaths() {
  return listFindings().map((finding) => ({
    params: { runId: finding.runId, finding: finding.finding },
  }));
}

const finding = getFinding(Astro.params.runId!, Astro.params.finding!);
if (!finding) throw new Error("Finding not found");
---

<Base title={`${finding.title} · Bitter Frontier`}>
  <article class="measure py-10">
    <p class="small-caps text-muted">Finding · {finding.data.source}</p>
    <div class="prose-frontier mt-7" set:html={finding.html} />
    <FindingFooter finding={finding} />
    <SourceTrail findings={[finding]} title="Source links" />
  </article>
</Base>
