---
import Base from "../../layouts/Base.astro";
import FindingFooter from "../../components/FindingFooter.astro";
import SourceTrail from "../../components/SourceTrail.astro";
import { metaDescription } from "../../lib/seo";
import { listCanonicalFindings, signalsCitingFinding, sourceLabel } from "../../lib/frontier";

export function getStaticPaths() {
  return listCanonicalFindings().map((finding) => ({
    params: { finding: finding.finding },
  }));
}

const finding = listCanonicalFindings().find((entry) => entry.finding === Astro.params.finding);
if (!finding) throw new Error("Finding not found");

const citedSignal = signalsCitingFinding(finding)[0];
const findingTitle = finding.title === finding.finding ? (citedSignal?.title ?? finding.title) : finding.title;
const findingSourceLabel = sourceLabel(String(finding.data.source ?? "coding agent"));
const findingKeywords = Array.from(new Set([
  findingSourceLabel,
  "coding agent finding",
  "source-backed finding",
  "agent harness",
  "Bitter Frontier",
]));
const findingDetail = finding.data.summary ?? citedSignal?.summary ?? finding.data.operator_consequence;
const findingDescription = metaDescription(
  findingDetail ? `${findingSourceLabel} source-backed coding agent finding: ${findingDetail}` : undefined,
  finding.data.summary,
  citedSignal?.summary,
  finding.data.operator_consequence,
  citedSignal?.whyActionBearing?.[0],
  finding.body,
  `${findingTitle} source-backed finding for ${findingSourceLabel}.`,
);
const findingModifiedDate = finding.data.corrected_on
  ?? finding.data.last_updated
  ?? finding.data.window?.end;
---

<Base
  title={`${findingTitle} | Source-Backed Finding | Bitter Frontier`}
  description={findingDescription}
  publishedDate={finding.data.window?.end}
  modifiedDate={findingModifiedDate}
  articleSection="Source-backed coding agent finding"
  authorName="Michael Ruescher"
  keywords={findingKeywords}
>
  <article class="measure py-10">
    <p class="small-caps text-muted">Finding / {finding.data.source}</p>
    <p class="issue-meta">Edited by Michael Ruescher</p>
    <div class="prose-frontier mt-7" set:html={finding.html} />
    <FindingFooter finding={finding} />
    <SourceTrail findings={[finding]} title="Source links" />
    <p class="rule mt-8 pt-5 font-mono text-sm text-muted">
      Versioned source: <a href={`/findings/${finding.runId}/${finding.finding}/`}>run artifact</a>
    </p>
  </article>
</Base>
