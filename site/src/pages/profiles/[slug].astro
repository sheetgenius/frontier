---
import Base from "../../layouts/Base.astro";
import FrontierLens from "../../components/FrontierLens.astro";
import ProfileStance from "../../components/ProfileStance.astro";
import { metaDescription } from "../../lib/seo";
import { gitFirstRevisionDate } from "../../lib/revision";
import { GH_BLOB_BASE } from "../../lib/site";
import { digestsForSource, findFindingByFindingId, formatDate, getProfile, inboundCompositionForSource, listProfiles, sourceLabel } from "../../lib/frontier";
import { marked } from "marked";

export function getStaticPaths() {
  return listProfiles().map((profile) => ({ params: { slug: profile.slug } }));
}

const profile = getProfile(Astro.params.slug!);
if (!profile) throw new Error("Profile not found");

const activeClaims = (profile.data.claims ?? []).filter((c: any) => c.status === "active");
const verifiedClaimReceipts = Array.from(new Map(
  activeClaims.map((claim: any) => [claim.finding_id ?? `claim:${claim.id}`, claim]),
).values());
const openQuestions = (profile.data.claims ?? []).filter((c: any) => c.status === "open_question");
const appearedIn = digestsForSource(profile.slug);

const INBOUND_CAP = 8;
const inboundAll = inboundCompositionForSource(profile.slug);
const inboundShown = inboundAll.slice(0, INBOUND_CAP);
const inboundOverflow = inboundAll.length > INBOUND_CAP;

const officialLinks = [
  profile.data.homepage && { label: "Homepage", href: profile.data.homepage },
  profile.data.repo && { label: "Repository", href: profile.data.repo },
  profile.data.docs && { label: "Docs", href: profile.data.docs },
  profile.data.changelog && { label: "Changelog", href: profile.data.changelog },
].filter(Boolean) as { label: string; href: string }[];

const xHandles = [
  ...(profile.data.x?.project ? [profile.data.x.project] : []),
  ...((profile.data.x?.maintainers ?? []) as any[]).map((m: any) => m.handle),
].filter(Boolean);

function humanizeId(id: string): string {
  return id.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}

function findingUrlFor(findingId: string | undefined | null): string | undefined {
  if (!findingId) return undefined;
  const finding = findFindingByFindingId(findingId);
  if (!finding) return undefined;
  return `/findings/${finding.finding}/`;
}

function splitLeadingOperatorRead(markdown: string): { operatorHtml: string; remainingHtml: string } {
  const heading = /^## Operator Read\s*$/m.exec(markdown);
  if (!heading || markdown.slice(0, heading.index).trim()) {
    return { operatorHtml: "", remainingHtml: marked.parse(markdown) as string };
  }

  const afterHeading = heading.index + heading[0].length;
  const nextHeading = /^##\s+/m.exec(markdown.slice(afterHeading));
  const sectionEnd = nextHeading ? afterHeading + nextHeading.index : markdown.length;
  return {
    operatorHtml: marked.parse(markdown.slice(heading.index, sectionEnd).trim()) as string,
    remainingHtml: marked.parse(markdown.slice(sectionEnd).trim()) as string,
  };
}

const profileLabel = profile.data.label ?? profile.slug;
const profileKeywords = Array.from(new Set([
  profileLabel,
  "coding agent stack research profile",
  "agent infrastructure",
  "AI software operations",
  "Bitter Frontier",
]));
const profileDescription = metaDescription(
  `${profileLabel} source-backed project profile: ${profile.data.tagline ?? profile.data.stance?.use_for ?? ""}`,
  profile.data.tagline,
  profile.data.stance?.use_for,
  `${profileLabel} project profile with sourced claims, operator stance, open questions, and the latest Bitter Frontier reporting.`,
);
const profilePublishedDate = gitFirstRevisionDate(
  profile.relativePath,
  formatDate(profile.data.first_published ?? profile.data.last_full_review ?? profile.data.last_updated),
);
const profileSections = splitLeadingOperatorRead(profile.body);
---

<Base
  title={`${profileLabel} Research Profile | Bitter Frontier`}
  description={profileDescription}
  publishedDate={profilePublishedDate}
  modifiedDate={profile.data.last_updated}
  articleSection="Coding agent stack research profile"
  authorName="Michael Ruescher"
  keywords={profileKeywords}
>
  <article class="measure py-10">
    <p class="small-caps text-muted">
      <a href="/profiles/">Profiles</a> / {profile.data.owner}
    </p>
    <h1 class="issue-title">{profileLabel}</h1>
    {profile.data.tagline && (
      <p class="profile-dek">{profile.data.tagline.replace(/^"|"$/g, "")}</p>
    )}
    <p class="issue-meta">
      Edited by Michael Ruescher / reviewed {formatDate(profile.data.last_full_review ?? profile.data.last_updated)}
    </p>

    {officialLinks.length > 0 && (
      <nav class="profile-links" aria-label="Official links">
        {officialLinks.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    )}

    {xHandles.length > 0 && (
      <p class="profile-social">
        On X{" "}
        {xHandles.map((h, i) => (
          <>{i > 0 && <span aria-hidden="true"> / </span>}<a href={`https://x.com/${h}`}>@{h}</a></>
        ))}
      </p>
    )}

    {profileSections.operatorHtml && (
      <div class="prose-frontier mt-9 rule pt-6" set:html={profileSections.operatorHtml} />
    )}

    <ProfileStance stance={profile.data.stance} asOf={formatDate(profile.data.last_updated)} />

    {profileSections.remainingHtml && (
      <div class="prose-frontier mt-9 rule pt-6" set:html={profileSections.remainingHtml} />
    )}

    <div class="mt-8 rule pt-6">
      <p class="small-caps text-muted">Verification</p>
      <p class="mt-3 font-mono text-sm text-muted">
        {profile.data.surface_class?.replaceAll("_", " ")} / evidence floor: {profile.data.evidence_floor?.replaceAll("_", " ")} / updated {formatDate(profile.data.last_updated)}
      </p>
    </div>

    {
      verifiedClaimReceipts.length > 0 && (
        <div class="mt-8 rule pt-6">
          <p class="small-caps text-muted">Verified claims</p>
          <ul class="mt-4 space-y-2">
            {verifiedClaimReceipts.map((claim: any) => {
              const href = findingUrlFor(claim.finding_id);
              const finding = findFindingByFindingId(claim.finding_id);
              const label = finding?.title ?? humanizeId(claim.id);
              return (
                <li class="font-mono text-sm">
                  {href ? (
                    <a href={href} class="hover:underline">{label}</a>
                  ) : (
                    <span>{label}</span>
                  )}
                  <span class="text-muted"> / verified {formatDate(claim.last_verified)}</span>
                </li>
              );
            })}
          </ul>
        </div>
      )
    }

    {
      openQuestions.length > 0 && (
        <div class="mt-6">
          <p class="small-caps text-muted">Open Questions</p>
          <ul class="mt-4 space-y-2">
            {openQuestions.map((claim: any) => {
              const href = findingUrlFor(claim.finding_id);
              return (
                <li class="font-mono text-sm text-muted">
                  {href ? (
                    <a href={href} class="hover:underline">{humanizeId(claim.id)}</a>
                  ) : (
                    <span>{humanizeId(claim.id)}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      )
    }

    {inboundShown.length > 0 && (
      <div class="mt-8 rule pt-5">
        <p class="small-caps text-muted">Used by other projects</p>
        <p class="text-muted" style="font-size: 0.85rem; margin-top: 0.4rem;">
          Reporting on other watched projects that explicitly integrate with {profile.data.label ?? profile.slug}.
        </p>
        <ul class="mt-3 space-y-2">
          {inboundShown.map((signal) => (
            <li class="font-mono text-sm">
              <a href={`/signals/${signal.id}/`} class="hover:underline">{signal.title}</a>
              <div class="text-muted" style="margin-top: 2px;">
                {signal.date} / from {signal.sources.map((s) => sourceLabel(s)).join(", ")}
              </div>
            </li>
          ))}
        </ul>
        {inboundOverflow && (
          <p class="mt-3 font-mono text-sm">
            <a href={`/signals/composes-with/${profile.slug}/`} class="hover:underline">
              Earlier: all {inboundAll.length} related signals -&gt;
            </a>
          </p>
        )}
      </div>
    )}

    {appearedIn.length > 0 && (
      <div class="mt-8 rule pt-5">
        <p class="small-caps text-muted font-mono text-sm">Featured in</p>
        <ul class="mt-2 space-y-1">
          {appearedIn.map((digest) => (
            <li class="font-mono text-sm">
              <a href={`/digests/${digest.slug}/`} class="hover:underline">
                {digest.data.title ?? digest.slug}
              </a>
              <span class="text-muted"> / {formatDate(digest.data.window?.end)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <p class="mt-8 rule pt-5 font-mono text-sm text-muted">
      Source policy: <a href={`/sources/#${profile.slug}`}>what Frontier watches and accepts as evidence</a>
    </p>
    <p class="mt-3 font-mono text-sm text-muted">
      Edited and maintained by Bitter Frontier.
    </p>
    <p class="mt-3">
      <a class="view-source" href={`${GH_BLOB_BASE}/${profile.relativePath}`}>
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        View source on GitHub
      </a>
    </p>
    <FrontierLens />
  </article>
</Base>
