---
import Base from "../../layouts/Base.astro";
import ProfileStance from "../../components/ProfileStance.astro";
import { digestsForSource, findFindingByFindingId, formatDate, getProfile, inboundCompositionForSource, listProfiles, sourceLabel } from "../../lib/frontier";

export function getStaticPaths() {
  return listProfiles().map((profile) => ({ params: { slug: profile.slug } }));
}

const profile = getProfile(Astro.params.slug!);
if (!profile) throw new Error("Profile not found");

const activeClaims = (profile.data.claims ?? []).filter((c: any) => c.status === "active");
const openQuestions = (profile.data.claims ?? []).filter((c: any) => c.status === "open_question");
const appearedIn = digestsForSource(profile.slug);

const INBOUND_CAP = 8;
const inboundAll = inboundCompositionForSource(profile.slug);
const inboundShown = inboundAll.slice(0, INBOUND_CAP);
const inboundOverflow = inboundAll.length > INBOUND_CAP;

function humanizeId(id: string): string {
  return id.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}

function findingUrlFor(findingId: string | undefined | null): string | undefined {
  if (!findingId) return undefined;
  const finding = findFindingByFindingId(findingId);
  if (!finding) return undefined;
  return `/findings/${finding.runId}/${finding.finding}/`;
}
---

<Base title={`${profile.data.label ?? profile.slug} · Bitter Frontier`}>
  <article class="measure py-10">
    <p class="small-caps text-muted">
      <a href="/profiles/">Profiles</a> · {profile.data.owner}
    </p>
    <h1 class="issue-title">{profile.data.label ?? profile.slug}</h1>
    <p class="issue-meta">
      {profile.data.surface_class?.replaceAll("_", " ")} ·
      evidence floor: {profile.data.evidence_floor?.replaceAll("_", " ")} ·
      updated {formatDate(profile.data.last_updated)}
    </p>

    <ProfileStance stance={profile.data.stance} asOf={formatDate(profile.data.last_updated)} />

    {
      activeClaims.length > 0 && (
        <div class="mt-8 rule pt-6">
          <p class="small-caps text-muted">Active Claims</p>
          <ul class="mt-4 space-y-2">
            {activeClaims.map((claim: any) => {
              const href = findingUrlFor(claim.finding_id);
              return (
                <li class="font-mono text-sm">
                  {href ? (
                    <a href={href} class="hover:underline">{humanizeId(claim.id)}</a>
                  ) : (
                    <span>{humanizeId(claim.id)}</span>
                  )}
                  <span class="text-muted"> · verified {formatDate(claim.last_verified)}</span>
                </li>
              );
            })}
          </ul>
        </div>
      )
    }

    {
      openQuestions.length > 0 && (
        <div class="mt-6">
          <p class="small-caps text-muted">Open Questions</p>
          <ul class="mt-4 space-y-2">
            {openQuestions.map((claim: any) => {
              const href = findingUrlFor(claim.finding_id);
              return (
                <li class="font-mono text-sm text-muted">
                  {href ? (
                    <a href={href} class="hover:underline">{humanizeId(claim.id)}</a>
                  ) : (
                    <span>{humanizeId(claim.id)}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      )
    }

    {inboundShown.length > 0 && (
      <div class="mt-8 rule pt-5">
        <p class="small-caps text-muted">Inbound composition</p>
        <p class="text-muted" style="font-size: 0.85rem; margin-top: 0.4rem;">
          Signals from other watched providers whose finding declares it composes with {profile.data.label ?? profile.slug}.
        </p>
        <ul class="mt-3 space-y-2">
          {inboundShown.map((signal) => (
            <li class="font-mono text-sm">
              <a href={`/signals/${signal.id}/`} class="hover:underline">{signal.title}</a>
              <div class="text-muted" style="margin-top: 2px;">
                {signal.date} · from {signal.sources.map((s) => sourceLabel(s)).join(", ")}
              </div>
            </li>
          ))}
        </ul>
        {inboundOverflow && (
          <p class="mt-3 font-mono text-sm">
            <a href={`/signals/composes-with/${profile.slug}/`} class="hover:underline">
              earlier — all {inboundAll.length} inbound composition signals →
            </a>
          </p>
        )}
      </div>
    )}

    <div class="prose-frontier mt-9 rule pt-6" set:html={profile.html} />

    {appearedIn.length > 0 && (
      <div class="mt-8 rule pt-5">
        <p class="small-caps text-muted font-mono text-sm">Featured in</p>
        <ul class="mt-2 space-y-1">
          {appearedIn.map((digest) => (
            <li class="font-mono text-sm">
              <a href={`/digests/${digest.slug}/`} class="hover:underline">
                {digest.data.title ?? digest.slug}
              </a>
              <span class="text-muted"> · {formatDate(digest.data.window?.end)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <p class="mt-8 rule pt-5 font-mono text-sm text-muted">
      Source contract: <a href={`/sources/`}>{profile.data.source_contract}</a>
      {profile.data.homepage && (
        <> · <a href={profile.data.homepage}>{profile.data.homepage}</a></>
      )}
    </p>
    <p class="mt-3 font-mono text-sm text-muted">
      Profiles are maintained by the <a class="hover:underline" href="https://bitter.sh">Bitter</a> research loop.
    </p>
  </article>
</Base>
