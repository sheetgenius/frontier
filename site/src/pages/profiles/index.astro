---
import Base from "../../layouts/Base.astro";
import { formatDate, listProfiles } from "../../lib/frontier";
const profiles = listProfiles();
---

<Base
  title="AI Coding Agent and Infrastructure Research Profiles"
  description="Dated, source-backed profiles for Codex, Claude Code, Gemini CLI, Agent Flywheel, OpenHands, and other projects across the coding-agent stack."
  keywords={["coding agent research profiles", "agent infrastructure research", "Codex", "Claude Code", "Agent Flywheel", "Gemini CLI", "OpenHands"]}
>
  <section class="measure py-10">
    <p class="small-caps text-muted">Profiles</p>
    <h1 class="issue-title">Dated project profiles.</h1>
    <p class="publication-dek">
      One page per watched project. Each profile records what Frontier could verify at a stated date, the operator posture that follows, and the questions still open.
    </p>
    <div class="mt-9 space-y-7">
      {
        profiles.map((profile) => (
            <a class="block no-underline hover:underline" href={`/profiles/${profile.slug}/`}>
              <div class="small-caps text-muted">
                {profile.data.owner} / reviewed {formatDate(profile.data.last_updated)}
              </div>
              <h2 class="signal-title">{profile.data.label ?? profile.slug}</h2>
              {profile.data.tagline && (
                <p class="profile-row-dek">{profile.data.tagline.replace(/^"|"$/g, "")}</p>
              )}
            </a>
          ))
      }
    </div>
  </section>
</Base>
