---
import "../styles/global.css";
import { GH_BLOB_BASE, GH_REPO_URL, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from "../lib/site";
import { ogImageForPath } from "../lib/og";

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  canonicalPath,
  robots,
  publishedDate,
  modifiedDate,
  articleSection,
  keywords,
} = Astro.props;
// Per-page OG card (build-time, under /og/) when one exists; otherwise the
// site-wide static fallback (/og.png). An explicit non-default `image` prop
// still wins, so callers can override.
const ogImage = image ?? ogImageForPath(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, SITE_URL).toString();
const pageTitle = title === SITE_TITLE ? title : `${title}`;
const path = Astro.url.pathname;
const isDetail = /^\/(digests|signals|profiles|findings)\/.+/.test(path);
const ogType = isDetail ? "article" : "website";
const jsonLdType = path === "/" ? "WebSite" : isDetail ? "Article" : "CollectionPage";
const keywordList = Array.isArray(keywords) ? keywords.filter(Boolean) : keywords ? [keywords] : [];
const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": jsonLdType,
  "@id": `${canonicalUrl}#${jsonLdType.toLowerCase()}`,
  name: pageTitle,
  description,
  url: canonicalUrl,
  image: ogImage,
  inLanguage: "en",
  publisher: {
    "@type": "Organization",
    name: "Bitter",
    url: "https://bitter.sh"
  },
  isPartOf: {
    "@type": "Periodical",
    name: SITE_TITLE,
    url: SITE_URL
  }
};

if (jsonLdType === "Article") {
  jsonLd.headline = pageTitle;
  jsonLd.mainEntityOfPage = {
    "@type": "WebPage",
    "@id": canonicalUrl
  };
  jsonLd.isAccessibleForFree = true;
  if (publishedDate) jsonLd.datePublished = publishedDate;
  if (modifiedDate || publishedDate) jsonLd.dateModified = modifiedDate ?? publishedDate;
  if (articleSection) jsonLd.articleSection = articleSection;
  if (keywordList.length > 0) jsonLd.keywords = keywordList;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Bitter Frontier" href="/rss.xml" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <header class="wide-measure site-header">
      <a class="masthead-wordmark" href="/">
        <span class="wordmark-name">Bitter Frontier</span>
        <span class="wordmark-tag">Receipts for the agentic-coding frontier</span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <span class="nav-sections">
          <a href="/digests/">Digests</a>
          <a href="/profiles/">Profiles</a>
          <a href="/signals/">Signals</a>
          <a href="/runs/">Evidence</a>
          <a href="/about/">About</a>
        </span>
        <span class="nav-controls">
          <a class="nav-github" href={GH_REPO_URL} aria-label="Bitter Frontier on GitHub">
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            <span class="nav-github-label">GitHub</span>
          </a>
          <button
            id="theme-toggle"
            class="nav-theme"
            type="button"
            aria-label="Switch color theme"
            aria-pressed="false"
            title="Switch color theme"
          >
            <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
            </svg>
          </button>
        </span>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="measure site-footer">
      <p class="footer-tagline">Every claim needs a source. Every recommendation should change what someone does next.</p>
      <p class="footer-byline">Bitter Frontier is produced by <a class="hover:underline" href="https://bitter.sh">Bitter</a>.</p>
      <div class="footer-open">
        <a class="footer-open-lead" href={GH_REPO_URL}>
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          Open source on GitHub
        </a>
        <span class="footer-sep" aria-hidden="true">/</span>
        <a href={`${GH_BLOB_BASE}/CONTRIBUTING.md`}>Contribute</a>
        <span class="footer-sep" aria-hidden="true">/</span>
        <a class="footer-license" href={`${GH_BLOB_BASE}/LICENSE`}>MIT + CC BY 4.0</a>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.getElementById("theme-toggle");
        const sync = () => toggle?.setAttribute("aria-pressed", root.classList.contains("dark") ? "true" : "false");
        sync();
        toggle?.addEventListener("click", () => {
          root.classList.toggle("dark");
          localStorage.setItem("theme", root.classList.contains("dark") ? "dark" : "light");
          sync();
        });
      })();
    </script>
  </body>
</html>
