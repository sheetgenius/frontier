---
import "../styles/global.css";
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from "../lib/site";
import { ogImageForPath } from "../lib/og";

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image } = Astro.props;
// Per-page OG card (build-time, under /og/) when one exists; otherwise the
// site-wide static fallback (/og.png). An explicit non-default `image` prop
// still wins, so callers can override.
const ogImage = image ?? ogImageForPath(Astro.url.pathname);
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const pageTitle = title === SITE_TITLE ? title : `${title}`;
const path = Astro.url.pathname;
const isDetail = /^\/(digests|signals|profiles)\/.+/.test(path);
const ogType = isDetail ? "article" : "website";
const jsonLdType = path === "/" ? "WebSite" : isDetail ? "Article" : "CollectionPage";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": jsonLdType,
  name: pageTitle,
  description,
  url: canonicalUrl,
  image: ogImage,
  publisher: {
    "@type": "Organization",
    name: "Bitter",
    url: "https://bitter.sh"
  },
  isPartOf: {
    "@type": "Periodical",
    name: SITE_TITLE,
    url: SITE_URL
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Bitter Frontier" href="/rss.xml" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <header class="wide-measure site-header">
      <a class="small-caps whitespace-nowrap no-underline" href="/">Bitter Frontier</a>
      <nav class="site-nav">
        <a class="underline underline-offset-4" href="/digests/">Digests</a>
        <a class="underline underline-offset-4" href="/profiles/">Profiles</a>
        <a class="underline underline-offset-4" href="/signals/">Signals</a>
        <a class="underline underline-offset-4" href="/runs/">Evidence</a>
        <a class="underline underline-offset-4" href="/about/">About</a>
        <button
          id="theme-toggle"
          class="text-inherit bg-transparent border-0 p-0 cursor-pointer hover:underline"
          type="button"
          aria-label="Switch color theme"
          aria-pressed="false"
        >
          Theme
        </button>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="measure rule mt-20 py-8 text-sm text-muted">
      <p class="font-mono">Every claim needs a source. Every recommendation should change what someone does next.</p>
      <p class="mt-3 font-mono">Bitter Frontier is produced by <a class="hover:underline" href="https://bitter.sh">Bitter</a>.</p>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.getElementById("theme-toggle");
        const sync = () => toggle?.setAttribute("aria-pressed", root.classList.contains("dark") ? "true" : "false");
        sync();
        toggle?.addEventListener("click", () => {
          root.classList.toggle("dark");
          localStorage.setItem("theme", root.classList.contains("dark") ? "dark" : "light");
          sync();
        });
      })();
    </script>
  </body>
</html>
